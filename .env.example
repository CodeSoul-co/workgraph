HYPHA_CORE_DIR=./hypha
WORKGRAPH_DATA_DIR=./data
WORKGRAPH_OUTPUT_DIR=./outputs

# Model provider defaults for benchmark runs. Fill these in local .env only.
WORKGRAPH_MODEL_PROVIDER=deepseek
WORKGRAPH_MODEL=deepseek-chat

# OpenAI-compatible providers.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
TOGETHER_API_KEY=
TOGETHER_BASE_URL=https://api.together.xyz/v1
PERPLEXITY_API_KEY=
PERPLEXITY_BASE_URL=https://api.perplexity.ai

# Non-OpenAI-compatible providers.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
GOOGLE_API_KEY=
